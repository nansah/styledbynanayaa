Options -Indexes
RewriteEngine On
RewriteBase /

# ── Redirect old blog-*.html root URLs to new /blog/* paths ──────
RewriteRule ^blog-fashion(\.html)?$ /blog/fashion [R=301,L,NE]
RewriteRule ^blog-faith(\.html)?$   /blog/faith   [R=301,L,NE]
RewriteRule ^blog-lifestyle(\.html)?$ /blog/lifestyle [R=301,L,NE]
RewriteRule ^blog-post(\.html)?$    /blog/post    [R=301,L,NE]

# ── Strip .html from all URLs (301 redirect) ──────────────────────
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# ── Serve root .html files for clean URLs ────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# ── Serve blog/ subfolder .html files for clean URLs ─────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(blog/[^/]+)/?$ $1.html [L]

# ── Security headers ──────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Cache static assets ───────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
